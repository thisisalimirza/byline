# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Anthropic — used when users run on credits (not own key)
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Vercel KV — auto-injected by Vercel when you connect a KV store in the dashboard.
# For local dev with KV, copy these from your Vercel project settings → Storage.
# Without these, the app uses an in-memory store (fine for local dev, resets on restart).
KV_REST_API_URL=https://...
KV_REST_API_TOKEN=...
